{
  "name": "@hasna/economy-sdk",
  "version": "0.2.1",
  "description": "SDK client for @hasna/economy REST API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasna/economy.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/hasna/economy/issues"
  },
  "homepage": "https://github.com/hasna/economy/tree/main/sdk#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --packages external && tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "bun-types": "latest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "Apache-2.0"
}
